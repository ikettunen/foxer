{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GlossaryTerm",
  "description": "A Finnish paragliding terminology entry",
  "type": "object",
  "required": ["id", "type", "termFi", "termEn", "definition"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string", "enum": ["glossary_term"] },
    "termFi": { "type": "string" },
    "termEn": { "type": "string" },
    "definition": { "type": "string" },
    "relatedModuleIds": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
