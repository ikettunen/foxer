{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quiz",
  "description": "End-of-module quiz with questions and answer key",
  "type": "object",
  "required": ["id", "type", "moduleId", "locale", "questions"],
  "properties": {
    "id": { "type": "string", "description": "e.g. pp1-day1-quiz" },
    "type": { "type": "string", "enum": ["quiz"] },
    "moduleId": { "type": "string" },
    "locale": { "type": "string", "enum": ["fi", "en"] },
    "passMark": { "type": "integer", "description": "Minimum correct answers to pass", "default": 3 },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "answerType", "correctAnswer"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "answerType": { "type": "string", "enum": ["multiple_choice", "free_text"] },
          "options": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "text"],
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" }
              }
            },
            "description": "Required when answerType is multiple_choice"
          },
          "correctAnswer": { "type": "string", "description": "Option id for multiple_choice, or model answer text for free_text" },
          "explanation": { "type": "string", "description": "Shown to student after answering" }
        }
      }
    }
  }
}
